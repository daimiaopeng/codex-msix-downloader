{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "codex-msix-downloader",
  "main": "src/index.ts",
  "compatibility_date": "2024-03-20",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "vars": {
    "STORE_URL": "https://apps.microsoft.com/detail/9plm9xgg6vks?hl=zh-CN",
    "QUERY_TYPE": "url",
    "MARKET": "US",
    "RING": "RP",
    "LANGUAGE": "zh-CN",
    "NAME_CONTAINS": "OpenAI.Codex",
    "ARCH": "x64",
    "EXTENSION": ".msix"
  }
}
